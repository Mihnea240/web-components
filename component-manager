#!/usr/bin/env python3
import os
import re
import sys
import textwrap
from pathlib import Path

# --- Configuration Constants ---
BASE_DIR = Path(__file__).parent
COMPONENTS_DIR = BASE_DIR / "core" / "components"
DTS_FILE = BASE_DIR / "core" / "components" / "custom-elements.d.ts"
DEMOS_DIR = BASE_DIR / "demos"

# --- Blueprints (Templates) ---
# We use double {{ }} to escape literal braces for .format()

PACKAGE_TEMPLATE = """{{
  "name": "@mihnea240/{tag_name}",
  "version": "1.0.0",
  "type": "module",
  "exports": {{
    ".": "./index.ts"
  }}
}}"""

VITE_CONFIG_TEMPLATE = """import {{ defineConfig }} from 'vite';

export default defineConfig({{
  build: {{
    lib: {{ 
      entry: './index.ts', 
      fileName: '{tag_name}', 
      formats: ['es'] 
    }},
    rollupOptions: {{ 
      external: [/^lit-html/, /^@mihnea240\\/ui-core/] 
    }}
  }}
}});"""

COMPONENT_TEMPLATE = """import {{ compose }} from "@core/decorators";

@compose("{tag_name}")
export class {class_name} extends HTMLElement {{
    connectedCallback() {{
        console.log('<{tag_name}> connected');
    }}
}}
"""

DEMO_HTML_TEMPLATE = """<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Demo: {tag_name}</title>
</head>
<body>
    <{tag_name}></{tag_name}>
    <script type="module" src="./main.ts"></script>
</body>
</html>
"""

DEMO_MAIN_TEMPLATE = """import '@components/{tag_name}';

console.log('Demo for {tag_name} initialized');
"""

class BridgeProject:
    def __init__(self):
        self.components = self._scan_components()

    def _scan_components(self):
        """Finds all directories in components folder that look like custom elements."""
        if not COMPONENTS_DIR.exists():
            return []
        return [d.name for d in COMPONENTS_DIR.iterdir() if d.is_dir() and "-" in d.name and d.name != "custom-elements.d.ts"]

    def to_pascal(self, tag_name):
        return "".join(word.capitalize() for word in tag_name.split("-"))

    def create_component(self, tag_name):
        # Enforce W3C Custom Element naming (must contain a hyphen)
        if not re.match(r'^[a-z][a-z0-9-]*-[a-z0-9-]+$', tag_name):
            print(f"❌ Error: '{tag_name}' is not a valid custom element name.")
            return

        pkg_path = COMPONENTS_DIR / tag_name
        demo_path = DEMOS_DIR / tag_name
        
        if pkg_path.exists():
            print(f"⚠️  Component <{tag_name}> already exists. Skipping creation.")
            return

        pkg_path.mkdir(parents=True)
        demo_path.mkdir(parents=True)

        class_name = self.to_pascal(tag_name)

        # File generation map
        files_to_create = {
            pkg_path / "package.json": PACKAGE_TEMPLATE.format(tag_name=tag_name),
            pkg_path / "vite.config.js": VITE_CONFIG_TEMPLATE.format(tag_name=tag_name),
            pkg_path / "index.ts": COMPONENT_TEMPLATE.format(tag_name=tag_name, class_name=class_name),
            demo_path / "index.html": DEMO_HTML_TEMPLATE.format(tag_name=tag_name),
            demo_path / "main.ts": DEMO_MAIN_TEMPLATE.format(tag_name=tag_name)
        }

        for path, content in files_to_create.items():
            with open(path, "w") as f:
                f.write(content.strip() + "\n")
        
        print(f"✅ Successfully initialized <{tag_name}>")
        self.sync_types()

    def sync_types(self):
        """Rebuilds the custom-elements.d.ts file from scratch based on folders."""
        components = sorted(self._scan_components())
        imports = []
        mappings = []

        for tag in components:
            class_name = self.to_pascal(tag)
            # Paths are relative to the .d.ts file location
            imports.append(f"import type {{ {class_name} }} from '@components/{tag}'")
            mappings.append(f"    '{tag}': {class_name};")

        content = [
            "/* Auto-generated by manage.py - DO NOT EDIT */",
            *imports,
            "",
            "declare global {",
            "  interface HTMLElementTagNameMap {",
            *mappings,
            "  }",
            "}",
            ""
        ]

        with open(DTS_FILE, "w") as f:
            f.write("\n".join(content))
        
        print(f"✅ Sync complete: {len(components)} components mapped in types.")

    def run_all_demos(self):
        """Run all demos in the demos folder in parallel (like run-demos.sh)."""
        import subprocess
        demos = [d for d in DEMOS_DIR.iterdir() if d.is_dir()]
        if not demos:
            print("No demos found.")
            return
        print("Starting all demos in parallel...\n")
        procs = []
        for demo in demos:
            demo_name = demo.name
            print(f"Starting demo: {demo_name}")
            # You may want to adjust this command to match your npm script
            proc = subprocess.Popen(["npm", "run", "demo", f"--name={demo_name}"])
            procs.append(proc)
        print("\nAll demos started. Press Ctrl+C to stop all demos.\n")
        try:
            for proc in procs:
                proc.wait()
        except KeyboardInterrupt:
            print("\nStopping all demos...")
            for proc in procs:
                proc.terminate()
            print("All demos stopped.")

if __name__ == "__main__":
    project = BridgeProject()
    
    if len(sys.argv) < 2:
        print("Usage: python manage.py <tag-name> | sync | run-demos")
        sys.exit(1)

    cmd = sys.argv[1]
    if cmd == "sync":
        project.sync_types()
    elif cmd == "run-demos":
        project.run_all_demos()
    else:
        project.create_component(cmd)