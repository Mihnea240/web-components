{
	"compilerOptions": {
		"target": "ES2022", // Or higher
		"module": "ESNext",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		/* Stage 3 Decorators Settings */
		"experimentalDecorators": false, // Keep false for Stage 3
		"emitDecoratorMetadata": false, // Stage 3 does not support this yet
		"useDefineForClassFields": true,
		"lib": [
			"ES2022",
			"DOM",
			"ESNext"
		],
		"strict": true,
		"noImplicitAny": false,
		"paths": {
			"@core/*": ["./core/*"],
			"@decorators": ["./core/decorators/index"],
			"@decorators/*": ["./core/decorators/*"],
			"@components/*": ["./core/components/*/index.ts"]
		}
	},
	"include": [
		"core/components/custom-elements.d.ts",
		"core/components/**/*",
		"core/**/*",
		"demos/**/*",
	]
}